{
  "name": "bcdatamapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "citypg:sync": "./run-in-pgmaps.sh node datascrapers/sync-citypg-arcgis.mjs",
    "icbc:sync": "./run-in-pgmaps.sh node datascrapers/sync-icbc-tableau.mjs",
    "heat-shade:sync": "./run-in-pgmaps.sh node datascrapers/sync-heat-shade-data.mjs",
    "transit:gtfs:sync": "./run-in-pgmaps.sh node datascrapers/sync-transit-gtfs.mjs",
    "watersheds:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-fwa-watersheds.mjs",
    "watersheds:dev": "./run-in-pgmaps.sh node datascrapers/build-dev-bc-fwa-watersheds.mjs",
    "nr-admin:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-nr-admin.mjs",
    "uwr:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-uwr.mjs",
    "drought:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-drought.mjs",
    "drought:canonical": "./run-in-pgmaps.sh node datascrapers/build-bc-drought-canonical.mjs",
    "flood:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-rfc-flood-advisories.mjs",
    "crown-tenures:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-crown-tenures.mjs",
    "range-tenures:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-range-tenures.mjs",
    "mineral-tenures:sync": "./run-in-pgmaps.sh node datascrapers/sync-bc-mineral-tenures.mjs",
    "wars:sync": "./run-in-pgmaps.sh python3 datascrapers/sync-bc-wars.py",
    "cimd:sync": "./run-in-pgmaps.sh node datascrapers/sync-cimd.mjs",
    "canue:bc:sync": "./run-in-pgmaps.sh node datascrapers/sync-canue-bc.mjs",
    "canue:bc:sync:all-years": "./run-in-pgmaps.sh node datascrapers/sync-canue-bc.mjs --all-years true",
    "canue:bc:sync:all-cadences": "./run-in-pgmaps.sh node datascrapers/sync-canue-bc.mjs --all-years true --cadence both",
    "canue:bc:sync:monthly": "./run-in-pgmaps.sh node datascrapers/sync-canue-bc.mjs --all-years true --cadence monthly --gzip true",
    "canue:bc:inventory": "./run-in-pgmaps.sh node datascrapers/inventory-canue-source.mjs",
    "canue:map-plan": "./run-in-pgmaps.sh python3 datascrapers/plan-canue-map-layers.py",
    "canue:map-layer": "./run-in-pgmaps.sh python3 datascrapers/build-canue-map-layer.py",
    "canue:pmtiles": "./run-in-pgmaps.sh python3 datascrapers/build-canue-pmtiles-batch.py",
    "canue:app-catalog": "./run-in-pgmaps.sh python3 datascrapers/build-canue-app-catalog.py",
    "canue:v2:pmtiles": "./run-in-pgmaps.sh python3 datascrapers/build-canue-family-pmtiles.py",
    "canue:v2:catalog": "./run-in-pgmaps.sh python3 datascrapers/build-canue-v2-app-catalog.py",
    "canue:v2:validate": "./run-in-pgmaps.sh python3 datascrapers/validate-canue-v2-catalog.py",
    "canue:v2:aggregates": "./run-in-pgmaps.sh python3 datascrapers/build-canue-v2-postal-boundary-aggregates.py",
    "canue:v2:aggregates:pmtiles": "./run-in-pgmaps.sh node datascrapers/build-canue-v2-boundary-aggregates.mjs",
    "canue:v2:aggregates:finalize": "./run-in-pgmaps.sh bash datascrapers/finalize-canue-v2-aggregates-r2.sh",
    "canue:v2:finalize": "./run-in-pgmaps.sh bash datascrapers/finalize-canue-v2-r2.sh",
    "canue:bc:membership": "./run-in-pgmaps.sh node datascrapers/build-canue-postal-membership.mjs",
    "canue:bc:gzip": "./run-in-pgmaps.sh node datascrapers/gzip-canue-csv.mjs",
    "canue:bc:boundaries": "./run-in-pgmaps.sh node datascrapers/build-canue-boundary-aggregates.mjs",
    "census:sync": "./run-in-pgmaps.sh node datascrapers/build-census-hierarchy.mjs",
    "census:variables": "./run-in-pgmaps.sh python3 datascrapers/build-census-variables.py",
    "bc-assessment:build": "./run-in-pgmaps.sh python3 datascrapers/build-bc-assessment.py",
    "bc-assessment:refresh": "./run-in-pgmaps.sh python3 datascrapers/refresh-bc-assessment.py",
    "food-health:refresh": "./run-in-pgmaps.sh python3 datascrapers/food-health/fetch_incremental.py --city \"Prince George\" --output public/data/restaurants.json --delay 5",
    "food-health:geocode": "./run-in-pgmaps.sh python3 datascrapers/food-health/geocode_restaurants.py --file public/data/restaurants.json --delay 1.5",
    "walkability:build": "./run-in-pgmaps.sh node datascrapers/build-walkability-web.mjs",
    "walkability:import-supplements": "./run-in-pgmaps.sh node datascrapers/import-walkability-supplements.mjs",
    "walkability:build-grid-heatmap": "./run-in-pgmaps.sh node datascrapers/build-walkability-grid-heatmap.mjs"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "@turf/bbox-clip": "^7.2.0",
    "@turf/boolean-intersects": "^7.2.0",
    "@turf/boolean-point-in-polygon": "^7.2.0",
    "@turf/centroid": "^7.2.0",
    "@turf/simplify": "^7.2.0",
    "@turf/turf": "^6.5.0",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.1",
    "rbush": "^4.0.1"
  }
}
