{
  "id": "bc-rfc-flood-advisories",
  "title": "BC River Forecast Centre Flood Advisories Bridge",
  "version": 1,
  "generatedFrom": {
    "script": "datascrapers/sync-bc-rfc-flood-advisories.mjs",
    "command": "npm run flood:sync",
    "primaryOutput": "public/data/flood/advisories.json",
    "manifest": "public/data/flood/manifest.json"
  },
  "source": {
    "name": "BC River Forecast Centre Flood Warnings and Advisories",
    "currentIndex": "https://bcrfc.env.gov.bc.ca/warnings/index.htm",
    "archiveCompleteness": "discoverable-not-authoritative",
    "notes": [
      "BC RFC does not expose a complete public archive listing for /warnings/advisories.",
      "Historical coverage is assembled from the current index, seed URLs, legacy probes, and Wayback CDX.",
      "Historical advisories do not include official polygons."
    ]
  },
  "normalizedRecord": {
    "sourceId": {
      "from": "id",
      "type": "string",
      "required": true,
      "description": "Stable local id derived from the advisory URL filename."
    },
    "sourceUrl": {
      "from": "url",
      "type": "string",
      "required": true
    },
    "downloadedFrom": {
      "from": "downloadedFrom",
      "type": "string|null",
      "description": "Actual downloaded URL. May be a Wayback capture when the live BC RFC URL is gone."
    },
    "sourceMethods": {
      "from": "sourceMethods",
      "type": "string[]",
      "allowedValues": [
        "current-index",
        "seed-file",
        "legacy-number-probe",
        "legacy-year-number-probe",
        "wayback-cdx"
      ]
    },
    "headline": {
      "from": "title",
      "type": "string",
      "required": true,
      "description": "Best extracted bulletin headline/title. May include ministry header in newer PDFs."
    },
    "issuedAt": {
      "from": "issuedAt",
      "type": "ISO-8601 string|null",
      "description": "Parsed bulletin issue/update timestamp when available."
    },
    "issuedAtLocal": {
      "from": "issuedAtLocal",
      "type": "string|null",
      "description": "Source-facing timestamp text after light cleanup."
    },
    "issuedYear": {
      "from": "issuedYear",
      "type": "number|null"
    },
    "timelineDate": {
      "from": "issuedAt",
      "type": "ISO-8601 string|null",
      "description": "Use for chronological ordering. Null records should stay in an undated archive bucket."
    },
    "timelinePrecision": {
      "derive": "issuedAt ? 'instant' : 'undated'",
      "type": "instant|undated"
    },
    "advisoryLevels": {
      "from": "levels",
      "type": "string[]",
      "allowedValues": [
        "High Streamflow Advisory",
        "Flood Watch",
        "Flood Warning"
      ],
      "sourcePreserving": true,
      "description": "A bulletin can contain multiple levels."
    },
    "statuses": {
      "from": "statuses",
      "type": "string[]",
      "allowedValues": [
        "issued",
        "updated",
        "upgraded",
        "downgraded",
        "maintained",
        "ended"
      ],
      "sourcePreserving": true,
      "description": "A bulletin can contain several statuses for different regions/rivers."
    },
    "primarySeverityRank": {
      "derive": "max(advisoryLevels)",
      "type": "number",
      "mapping": {
        "Unknown": 0,
        "High Streamflow Advisory": 1,
        "Flood Watch": 2,
        "Flood Warning": 3
      },
      "description": "UI ranking only. Do not replace source advisoryLevels."
    },
    "primarySeverityLabel": {
      "derive": "highest ranked advisoryLevels value",
      "type": "string",
      "description": "UI label for choropleth/legend grouping."
    },
    "namedAreas": {
      "from": "namedAreas",
      "type": "string[]",
      "description": "Lightly tokenized title areas. Useful for search, not authoritative geometry."
    },
    "boundaryMatches": {
      "from": "matchedBoundaries",
      "type": "array",
      "matchQuality": "inferred-name-match",
      "description": "Approximate local boundary matches inferred from title/body text.",
      "itemShape": {
        "source": "droughtBasin|fwaWatershedGroup|fwaAssessmentWatershed|fwaMajorWatershed",
        "id": "string",
        "name": "string"
      }
    },
    "rawPath": {
      "from": "rawPath",
      "type": "string"
    },
    "textPath": {
      "from": "textPath",
      "type": "string"
    },
    "duplicateUrls": {
      "from": "duplicateUrls",
      "type": "string[]",
      "description": "Additional source URLs merged into this record during dedupe."
    }
  },
  "severityRanking": [
    {
      "level": "Flood Warning",
      "rank": 3,
      "color": "#dc2626"
    },
    {
      "level": "Flood Watch",
      "rank": 2,
      "color": "#f97316"
    },
    {
      "level": "High Streamflow Advisory",
      "rank": 1,
      "color": "#facc15"
    },
    {
      "level": "Unknown",
      "rank": 0,
      "color": "#94a3b8"
    }
  ],
  "boundarySources": [
    {
      "id": "droughtBasin",
      "path": "public/data/drought/basins.geojson",
      "idField": "basinId",
      "nameField": "basinName",
      "recommendedUse": "Broad advisory region overlays"
    },
    {
      "id": "fwaWatershedGroup",
      "path": "public/data/boundaries/BCFWA/watershed_groups_province_simplified.geojson",
      "idField": "boundaryCode",
      "nameField": "boundaryName",
      "recommendedUse": "River/watershed advisory overlays"
    },
    {
      "id": "fwaAssessmentWatershed",
      "path": "public/data/boundaries/BCFWA/assessment_watersheds.geojson",
      "idField": "boundaryCode",
      "nameField": "boundaryName",
      "recommendedUse": "More granular river-name matches"
    },
    {
      "id": "fwaMajorWatershed",
      "path": "public/data/boundaries/BCFWA/major_watersheds_province_simplified.geojson",
      "idField": "boundaryCode",
      "nameField": "boundaryName",
      "recommendedUse": "Coarse watershed context"
    }
  ],
  "qualityFlags": {
    "undatedArchive": "issuedAt is null",
    "inferredBoundary": "matchedBoundaries length > 0",
    "waybackOnly": "downloadedFrom starts with https://web.archive.org/",
    "multiLevelBulletin": "levels length > 1",
    "multiStatusBulletin": "statuses length > 1"
  },
  "implementationRules": [
    "Use issuedAt for timeline sorting when present.",
    "Keep undated records searchable but outside dated animation buckets.",
    "Do not treat matchedBoundaries as official BC RFC polygons.",
    "Do not collapse multiple advisory levels into one source field; derive primarySeverityLabel separately for UI.",
    "Preserve rawPath/textPath for audit and parser debugging."
  ]
}
